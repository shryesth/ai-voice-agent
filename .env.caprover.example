# =============================================================================
# CAPROVER DEPLOYMENT CONFIGURATION
# =============================================================================
# Copy this file's contents to your CapRover App Config > Environment Variables
#
# IMPORTANT: In CapRover, enter each line as a separate environment variable
# Do NOT include comments (#) or empty lines in CapRover config
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
ENVIRONMENT=production
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
# Your CapRover app URL (used for Twilio webhooks)
PUBLIC_URL=https://shifo-supervisor.your-captain-domain.com

# =============================================================================
# OPENAI CONFIGURATION (REQUIRED)
# =============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# OpenAI model for text completions (translation, etc.)
OPENAI_MODEL=gpt-4o-mini

# OpenAI Realtime API settings (for voice calls)
OPENAI_REALTIME_MODEL=gpt-realtime-mini-2025-10-06
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_TEMPERATURE=0.6

# =============================================================================
# TWILIO CONFIGURATION (REQUIRED)
# =============================================================================
# Get your credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins
# Example: https://admin.example.com,https://app.example.com
# Use * to allow all origins (not recommended for production)
ALLOWED_ORIGINS=https://your-frontend-domain.com

# =============================================================================
# CONNECTION PREWARMER
# =============================================================================
# Pre-establish OpenAI connection for outbound calls to reduce latency
PRECONNECT_ENABLED=true
PRECONNECT_TIMEOUT_MS=60000

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================
TRANSCRIPTS_ENABLED=true
RECORDINGS_ENABLED=true
RECORDINGS_STORAGE_BACKEND=minio

# =============================================================================
# MONGODB CONFIGURATION
# =============================================================================
# CapRover MongoDB service: srv-captain--<app-name>
# Example: srv-captain--shifo-supervisor-mongodb
# For MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_URI=mongodb://srv-captain--shifo-supervisor-mongodb:27017
MONGODB_DB_NAME=shifo-supervisor

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# CapRover Redis service: srv-captain--<app-name>
# Example: srv-captain--shifo-supervisor-redis
REDIS_HOST=srv-captain--shifo-supervisor-redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# =============================================================================
# QUEUE CONFIGURATION
# =============================================================================
# Enable the managed queue system for bulk calls
QUEUE_ENABLED=true

# Run mode determines what processes run in this container:
#   - api: Only FastAPI server (use when running separate worker containers)
#   - worker: Only Celery worker (for dedicated worker containers)
#   - beat: Only Celery beat scheduler
#   - worker-beat: Worker + Beat (for dedicated worker container)
#   - all: API + Worker + Beat (all-in-one container using supervisord)
RUN_MODE=all

# Queue processor interval (how often to check for scheduled calls)
QUEUE_PROCESSOR_INTERVAL_SECONDS=30

# =============================================================================
# MINIO CONFIGURATION (S3-Compatible Storage)
# =============================================================================
# CapRover MinIO service: srv-captain--<app-name>
# Example: srv-captain--shifo-supervisor-minio
MINIO_ENDPOINT=srv-captain--shifo-supervisor-minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=shifo-supervisor
MINIO_RECORDINGS_BUCKET=call-recordings

# =============================================================================
# QUICK COPY-PASTE FOR CAPROVER
# =============================================================================
# Remove all comments and copy these lines directly to CapRover:
#
# ENVIRONMENT=production
# HOST=0.0.0.0
# PORT=3000
# LOG_LEVEL=info
# PUBLIC_URL=https://shifo-supervisor.your-captain-domain.com
