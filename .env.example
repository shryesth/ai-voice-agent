# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=voice_ai

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Twilio Credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+12025551234

# OpenAI Configuration
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-realtime-preview-2024-12-17

# Security
JWT_SECRET_KEY=generate-a-secure-random-key-here-use-secrets.token_urlsafe32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Application Settings
LOG_LEVEL=debug
LOG_FORMAT=text
ENVIRONMENT=development

# Configuration Overrides (from research.md)
# Container Architecture
ENABLE_SUPERVISOR_MODE=false

# Resource Limits
DOCKER_RESOURCE_LIMITS_ENABLED=false
API_CPU_LIMIT=2.0
API_MEMORY_LIMIT=2G
WORKER_CPU_LIMIT=1.0
WORKER_MEMORY_LIMIT=1G

# Secrets Management
USE_DOCKER_SECRETS=false

# Startup Validation
SKIP_STARTUP_VALIDATION=false

# Health Checks
HEALTH_CHECK_DEPENDENCIES=true
HEALTH_CHECK_CACHE_TTL=5

# Database Backups
ENABLE_AUTOMATED_BACKUPS=false
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=7

# Monitoring
ENABLE_PROMETHEUS_METRICS=true
ENABLE_DLQ_ALERTS=true
METRICS_UPDATE_INTERVAL=15

# Graceful Shutdown
GRACEFUL_SHUTDOWN_TIMEOUT=30
CELERY_WORKER_SHUTDOWN_TIMEOUT=600

# Deployment
ENABLE_ROLLING_UPDATES=true
SKIP_PREDEPLOY_HOOKS=false

# Network Segmentation
ENABLE_NETWORK_SEGMENTATION=false

# Celery Configuration
CELERY_WORKER_CONCURRENCY=2
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Campaign Queue Settings
QUEUE_PROCESSOR_INTERVAL=30
MAX_CONCURRENT_CALLS=10
MAX_RETRY_ATTEMPTS=3

# Call Configuration
MAX_CALL_DURATION_SECONDS=600
CARRIER_RATE_LIMIT_SECONDS=2

# Supported Languages
SUPPORTED_LANGUAGES=en,es,fr,ht
DEFAULT_LANGUAGE=en
