# Base Environment Configuration
# This file contains all configuration variables with development defaults
# Environment-specific files (.env.local, .env.uat, .env.prod) override these values

# ============================================================================
# CORE CONFIGURATION
# ============================================================================

# Application Environment (development, staging, production)
ENVIRONMENT=development
LOG_LEVEL=debug
LOG_FORMAT=text

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=voice_agent

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# TELEPHONY CONFIGURATION
# ============================================================================

# Twilio Credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+12025551234

# Public URL for Twilio webhooks and media streams
# This is used for both WebSocket (wss://) and HTTP (https://) callbacks
# For local development with ngrok: https://abc123.ngrok.io
# For production: https://your-domain.com
PUBLIC_URL=https://abc123.ngrok.io

# Optional: Explicit WebSocket URL (if different from PUBLIC_URL)
# If not set, will be automatically derived from PUBLIC_URL
# TWILIO_WEBSOCKET_URL=wss://your-domain.com/api/v1/webhooks/twilio/media

# ============================================================================
# AI CONFIGURATION
# ============================================================================

# OpenAI Configuration
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-realtime-mini-2025-10-06

# ============================================================================
# SECURITY
# ============================================================================

# JWT Configuration
JWT_SECRET_KEY=generate-a-secure-random-key-here-use-secrets.token_urlsafe32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
# Behavior varies by environment:
# - Development (ENVIRONMENT=development): Allow all origins (*)
# - Staging (ENVIRONMENT=staging): Allow all origins (*)
# - Production (ENVIRONMENT=production): Use CORS_ORIGINS (strict)
# Comma-separated list of allowed origins for production
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ORIGINS=  # Leave commented for empty list (default)
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600

# Bootstrap Admin Configuration
# Automatically creates a default admin user on first startup if no admins exist
# IMPORTANT: Change the default password immediately after first login
ENABLE_BOOTSTRAP_ADMIN=true
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# ============================================================================
# STORAGE CONFIGURATION (S3/MinIO)
# ============================================================================

# S3/MinIO Configuration (for call recordings)
# For MinIO: Set S3_ENDPOINT_URL to your MinIO server (e.g., http://localhost:9000)
# For AWS S3 or Hetzner Object Storage: Set S3_ENDPOINT_URL to the provider endpoint
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=voice-recordings
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1

# Recording Settings
RECORDING_ENABLED=true
RECORDING_FORMAT=mp3
RECORDING_SAMPLE_RATE=8000

# ============================================================================
# CONTAINER ARCHITECTURE
# ============================================================================

# Supervisor Mode (single container vs multi-container)
ENABLE_SUPERVISOR_MODE=false

# Resource Limits
DOCKER_RESOURCE_LIMITS_ENABLED=false
API_CPU_LIMIT=2.0
API_MEMORY_LIMIT=2G
WORKER_CPU_LIMIT=1.0
WORKER_MEMORY_LIMIT=1G

# Secrets Management
USE_DOCKER_SECRETS=false

# Network Segmentation
ENABLE_NETWORK_SEGMENTATION=false

# ============================================================================
# APPLICATION BEHAVIOR
# ============================================================================

# Startup Validation
SKIP_STARTUP_VALIDATION=false

# Health Checks
HEALTH_CHECK_DEPENDENCIES=true
HEALTH_CHECK_CACHE_TTL=5

# Database Backups
ENABLE_AUTOMATED_BACKUPS=false
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=7

# Monitoring
ENABLE_PROMETHEUS_METRICS=true
ENABLE_DLQ_ALERTS=true
METRICS_UPDATE_INTERVAL=15

# Graceful Shutdown
GRACEFUL_SHUTDOWN_TIMEOUT=30
CELERY_WORKER_SHUTDOWN_TIMEOUT=600

# Deployment
ENABLE_ROLLING_UPDATES=true
SKIP_PREDEPLOY_HOOKS=false

# ============================================================================
# CELERY CONFIGURATION
# ============================================================================

# Celery Worker Settings
CELERY_WORKER_CONCURRENCY=2
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# CAMPAIGN & CALL SETTINGS
# ============================================================================

# Campaign Queue Settings
QUEUE_PROCESSOR_INTERVAL=30
MAX_CONCURRENT_CALLS=10
MAX_RETRY_ATTEMPTS=3

# Call Configuration
MAX_CALL_DURATION_SECONDS=600
CARRIER_RATE_LIMIT_SECONDS=2

# ============================================================================
# LANGUAGE CONFIGURATION
# ============================================================================

# Supported Languages
SUPPORTED_LANGUAGES=en,es,fr,ht
DEFAULT_LANGUAGE=en

# Language-Specific Voice Configuration
VOICE_EN=alloy
VOICE_ES=shimmer
VOICE_FR=coral
VOICE_HT=alloy
