# Local Development Environment Configuration Template
# Copy this file to config/.env.local and replace placeholders with your values
# This file is tracked in git - DO NOT add real credentials here

# ============================================================================
# CORE CONFIGURATION
# ============================================================================

ENVIRONMENT=development
LOG_LEVEL=debug
LOG_FORMAT=text

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# MongoDB Configuration (docker-compose overrides to mongodb:27017 in containers)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=voice_agent

# Redis Configuration (docker-compose overrides to redis:6379 in containers)
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# TELEPHONY CONFIGURATION
# ============================================================================

# Twilio Credentials
TWILIO_ACCOUNT_SID=REPLACE_WITH_YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=REPLACE_WITH_YOUR_TWILIO_PHONE_NUMBER

# Public URL for Twilio webhooks and media streams
# UPDATE THIS with your ngrok URL when running locally
# Get ngrok URL: ngrok http 3000
PUBLIC_URL=https://your-ngrok-subdomain.ngrok-free.dev

# ============================================================================
# AI CONFIGURATION
# ============================================================================

# OpenAI Configuration
OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-realtime-mini-2025-10-06

# ============================================================================
# SECURITY
# ============================================================================

# JWT Configuration
JWT_SECRET_KEY=generate-a-secure-random-key-here-use-secrets.token_urlsafe32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
# Note: Development allows all origins by default for easier frontend testing
# CORS_ORIGINS is only enforced in production
# CORS_ORIGINS=  # Leave commented for allow-all (default in development)
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600

# ============================================================================
# STORAGE CONFIGURATION (MinIO Local)
# ============================================================================

# MinIO Local Configuration
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=voice-recordings
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1

# Recording Settings
RECORDING_ENABLED=true
RECORDING_FORMAT=mp3
RECORDING_SAMPLE_RATE=8000

# ============================================================================
# CONTAINER ARCHITECTURE
# ============================================================================

ENABLE_SUPERVISOR_MODE=false
DOCKER_RESOURCE_LIMITS_ENABLED=false
API_CPU_LIMIT=2.0
API_MEMORY_LIMIT=2G
WORKER_CPU_LIMIT=1.0
WORKER_MEMORY_LIMIT=1G
USE_DOCKER_SECRETS=false
ENABLE_NETWORK_SEGMENTATION=false

# ============================================================================
# APPLICATION BEHAVIOR
# ============================================================================

# Startup Validation
SKIP_STARTUP_VALIDATION=false

# Health Checks
HEALTH_CHECK_DEPENDENCIES=true
HEALTH_CHECK_CACHE_TTL=5

# Database Backups (disabled for local dev)
ENABLE_AUTOMATED_BACKUPS=false
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=7

# Monitoring
ENABLE_PROMETHEUS_METRICS=true
ENABLE_DLQ_ALERTS=true
METRICS_UPDATE_INTERVAL=15

# Graceful Shutdown
GRACEFUL_SHUTDOWN_TIMEOUT=30
CELERY_WORKER_SHUTDOWN_TIMEOUT=600

# Deployment
ENABLE_ROLLING_UPDATES=true
SKIP_PREDEPLOY_HOOKS=false

# ============================================================================
# CELERY CONFIGURATION
# ============================================================================

CELERY_WORKER_CONCURRENCY=2
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# CAMPAIGN & CALL SETTINGS
# ============================================================================

QUEUE_PROCESSOR_INTERVAL=30
MAX_CONCURRENT_CALLS=10
MAX_RETRY_ATTEMPTS=3
MAX_CALL_DURATION_SECONDS=600
CARRIER_RATE_LIMIT_SECONDS=2

# ============================================================================
# LANGUAGE CONFIGURATION
# ============================================================================

SUPPORTED_LANGUAGES=en,es,fr,ht
DEFAULT_LANGUAGE=en
VOICE_EN=alloy
VOICE_ES=shimmer
VOICE_FR=coral
VOICE_HT=alloy
