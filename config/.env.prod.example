# Production Environment Configuration Template
# This file is tracked in git - DO NOT add real credentials here
# For CapRover deployments: Set these variables via CapRover UI → App Configs → Environment Variables
# For Docker Compose deployments: Copy to config/.env.prod and replace placeholders

# ============================================================================
# CORE CONFIGURATION
# ============================================================================

ENVIRONMENT=production
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# MongoDB Configuration
MONGODB_URI=mongodb://REPLACE_WITH_PROD_MONGODB_USER:REPLACE_WITH_PROD_MONGODB_PASSWORD@REPLACE_WITH_PROD_MONGODB_HOST:27017/voice_agent?authSource=admin
MONGODB_DATABASE=voice_agent

# Redis Configuration
REDIS_URL=redis://REPLACE_WITH_PROD_REDIS_HOST:6379/0

# ============================================================================
# TELEPHONY CONFIGURATION
# ============================================================================

# Twilio Credentials (production)
TWILIO_ACCOUNT_SID=REPLACE_WITH_PROD_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_PROD_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=REPLACE_WITH_PROD_TWILIO_PHONE_NUMBER

# Public URL for Twilio webhooks
PUBLIC_URL=https://api.your-domain.com

# ============================================================================
# AI CONFIGURATION
# ============================================================================

# OpenAI Configuration
OPENAI_API_KEY=REPLACE_WITH_PROD_OPENAI_API_KEY
OPENAI_REALTIME_MODEL=gpt-realtime-mini-2025-12-15
OPENAI_LLM_MODEL=gpt-5-mini-2025-08-07
TRANSLATION_MODEL=gpt-5-mini-2025-08-07

# ============================================================================
# SECURITY
# ============================================================================

# JWT Configuration (generate a strong secret for production)
JWT_SECRET_KEY=REPLACE_WITH_PROD_JWT_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
CORS_ORIGINS=https://app.your-domain.com,https://admin.your-domain.com
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600

# Bootstrap Admin Configuration
# SECURITY: Bootstrap is DISABLED by default in production for security
# Only enable temporarily for initial setup, then disable after creating your admin users
# ENABLE_BOOTSTRAP_ADMIN=false  # Uncomment to disable (default: disabled in production)
# BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.com
# BOOTSTRAP_ADMIN_PASSWORD=REPLACE_WITH_VERY_STRONG_PASSWORD

# ============================================================================
# STORAGE CONFIGURATION (Hetzner Object Storage)
# ============================================================================

# Hetzner Object Storage Configuration
# nbg1 = Nuremberg, Germany = eu-central-1 region
S3_ENDPOINT_URL=https://nbg1.your-objectstorage.com
S3_BUCKET_NAME=shifo-supervisor
S3_ACCESS_KEY_ID=REPLACE_WITH_HETZNER_ACCESS_KEY
S3_SECRET_ACCESS_KEY=REPLACE_WITH_HETZNER_SECRET_KEY
S3_REGION=eu-central-1

# Recording Settings
RECORDING_ENABLED=true
RECORDING_FORMAT=mp3
RECORDING_SAMPLE_RATE=8000

# ============================================================================
# CONTAINER ARCHITECTURE
# ============================================================================

ENABLE_SUPERVISOR_MODE=false
DOCKER_RESOURCE_LIMITS_ENABLED=true
API_CPU_LIMIT=2.0
API_MEMORY_LIMIT=2G
WORKER_CPU_LIMIT=1.0
WORKER_MEMORY_LIMIT=1G
USE_DOCKER_SECRETS=false
ENABLE_NETWORK_SEGMENTATION=false

# ============================================================================
# APPLICATION BEHAVIOR
# ============================================================================

# Startup Validation
SKIP_STARTUP_VALIDATION=false

# Health Checks
HEALTH_CHECK_DEPENDENCIES=true
HEALTH_CHECK_CACHE_TTL=5

# Database Backups
ENABLE_AUTOMATED_BACKUPS=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=14

# Monitoring
ENABLE_PROMETHEUS_METRICS=true
ENABLE_DLQ_ALERTS=true
METRICS_UPDATE_INTERVAL=15

# Graceful Shutdown
GRACEFUL_SHUTDOWN_TIMEOUT=30
CELERY_WORKER_SHUTDOWN_TIMEOUT=600

# Deployment
ENABLE_ROLLING_UPDATES=true
SKIP_PREDEPLOY_HOOKS=false

# ============================================================================
# CELERY CONFIGURATION
# ============================================================================

CELERY_WORKER_CONCURRENCY=4
CELERY_BROKER_URL=redis://REPLACE_WITH_PROD_REDIS_HOST:6379/0
CELERY_RESULT_BACKEND=redis://REPLACE_WITH_PROD_REDIS_HOST:6379/0

# ============================================================================
# CAMPAIGN & CALL SETTINGS
# ============================================================================

QUEUE_PROCESSOR_INTERVAL=30
MAX_CONCURRENT_CALLS=20
MAX_RETRY_ATTEMPTS=3
MAX_CALL_DURATION_SECONDS=600
CARRIER_RATE_LIMIT_SECONDS=2

# ============================================================================
# LANGUAGE CONFIGURATION
# ============================================================================

SUPPORTED_LANGUAGES=en,es,fr,ht
DEFAULT_LANGUAGE=en
VOICE_EN=alloy
VOICE_ES=shimmer
VOICE_FR=coral
VOICE_HT=alloy
