# UAT/Staging Environment Configuration Template
# Copy this file to config/.env.uat and replace placeholders with actual values
# This file is tracked in git - DO NOT add real credentials here

# ============================================================================
# CORE CONFIGURATION
# ============================================================================

ENVIRONMENT=staging
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# MongoDB Configuration (update with UAT credentials)
MONGODB_URI=mongodb://REPLACE_WITH_UAT_MONGODB_HOST:27017
MONGODB_DATABASE=voice_agent_uat

# Redis Configuration
REDIS_URL=redis://REPLACE_WITH_UAT_REDIS_HOST:6379/0

# ============================================================================
# TELEPHONY CONFIGURATION
# ============================================================================

# Twilio Credentials (use UAT/test credentials)
TWILIO_ACCOUNT_SID=REPLACE_WITH_UAT_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_UAT_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=REPLACE_WITH_UAT_TWILIO_PHONE_NUMBER

# Public URL for Twilio webhooks
PUBLIC_URL=https://api-uat.your-domain.com

# ============================================================================
# AI CONFIGURATION
# ============================================================================

# OpenAI Configuration
OPENAI_API_KEY=REPLACE_WITH_UAT_OPENAI_API_KEY
OPENAI_MODEL=gpt-realtime-mini-2025-10-06

# ============================================================================
# SECURITY
# ============================================================================

# JWT Configuration (generate a new secret for UAT)
JWT_SECRET_KEY=REPLACE_WITH_UAT_JWT_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
# Note: UAT/Staging allows all origins by default for testing
# CORS_ORIGINS is only enforced in production
# CORS_ORIGINS=  # Leave commented for allow-all (default in staging)
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600

# ============================================================================
# STORAGE CONFIGURATION (MinIO UAT or Hetzner)
# ============================================================================

# Option 1: MinIO UAT Instance
# S3_ENDPOINT_URL=https://minio-uat.your-domain.com
# S3_BUCKET_NAME=voice-recordings-uat
# S3_ACCESS_KEY_ID=REPLACE_WITH_UAT_MINIO_ACCESS_KEY
# S3_SECRET_ACCESS_KEY=REPLACE_WITH_UAT_MINIO_SECRET_KEY

# Option 2: Hetzner Object Storage (UAT bucket)
# nbg1 = Nuremberg, Germany = eu-central-1 region
S3_ENDPOINT_URL=https://nbg1.your-objectstorage.com
S3_BUCKET_NAME=shifo-supervisor-uat
S3_ACCESS_KEY_ID=REPLACE_WITH_HETZNER_ACCESS_KEY
S3_SECRET_ACCESS_KEY=REPLACE_WITH_HETZNER_SECRET_KEY
S3_REGION=eu-central-1

# Recording Settings
RECORDING_ENABLED=true
RECORDING_FORMAT=mp3
RECORDING_SAMPLE_RATE=8000

# ============================================================================
# CONTAINER ARCHITECTURE
# ============================================================================

ENABLE_SUPERVISOR_MODE=false
DOCKER_RESOURCE_LIMITS_ENABLED=true
API_CPU_LIMIT=1.5
API_MEMORY_LIMIT=1536M
WORKER_CPU_LIMIT=1.0
WORKER_MEMORY_LIMIT=1G
USE_DOCKER_SECRETS=false
ENABLE_NETWORK_SEGMENTATION=false

# ============================================================================
# APPLICATION BEHAVIOR
# ============================================================================

# Startup Validation
SKIP_STARTUP_VALIDATION=false

# Health Checks
HEALTH_CHECK_DEPENDENCIES=true
HEALTH_CHECK_CACHE_TTL=5

# Database Backups
ENABLE_AUTOMATED_BACKUPS=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=7

# Monitoring
ENABLE_PROMETHEUS_METRICS=true
ENABLE_DLQ_ALERTS=true
METRICS_UPDATE_INTERVAL=15

# Graceful Shutdown
GRACEFUL_SHUTDOWN_TIMEOUT=30
CELERY_WORKER_SHUTDOWN_TIMEOUT=600

# Deployment
ENABLE_ROLLING_UPDATES=true
SKIP_PREDEPLOY_HOOKS=false

# ============================================================================
# CELERY CONFIGURATION
# ============================================================================

CELERY_WORKER_CONCURRENCY=2
CELERY_BROKER_URL=redis://REPLACE_WITH_UAT_REDIS_HOST:6379/0
CELERY_RESULT_BACKEND=redis://REPLACE_WITH_UAT_REDIS_HOST:6379/0

# ============================================================================
# CAMPAIGN & CALL SETTINGS
# ============================================================================

QUEUE_PROCESSOR_INTERVAL=30
MAX_CONCURRENT_CALLS=5
MAX_RETRY_ATTEMPTS=3
MAX_CALL_DURATION_SECONDS=600
CARRIER_RATE_LIMIT_SECONDS=2

# ============================================================================
# LANGUAGE CONFIGURATION
# ============================================================================

SUPPORTED_LANGUAGES=en,es,fr,ht
DEFAULT_LANGUAGE=en
VOICE_EN=alloy
VOICE_ES=shimmer
VOICE_FR=coral
VOICE_HT=alloy
