# ============================================================================
# CAPROVER ENVIRONMENT VARIABLES - PRODUCTION BACKEND
# App: acme-supervisor-backend
# Project: acme-supervisor
# ============================================================================
# Copy-paste these into CapRover UI → App Configs → Environment Variables
# Replace all REPLACE_WITH_* placeholders with actual values
# ============================================================================

# Core Configuration
ENVIRONMENT=production
LOG_LEVEL=info
LOG_FORMAT=json

# Database Configuration (CapRover internal services)
MONGODB_URI=mongodb://srv-captain--acme-supervisor-mongodb:27017/acme
MONGODB_DATABASE=acme

# Redis Configuration (CapRover internal services)
REDIS_URL=redis://srv-captain--acme-supervisor-redis:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://srv-captain--acme-supervisor-redis:6379/0
CELERY_RESULT_BACKEND=redis://srv-captain--acme-supervisor-redis:6379/0

# Twilio Credentials (PRODUCTION)
TWILIO_ACCOUNT_SID=REPLACE_WITH_PROD_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_PROD_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=REPLACE_WITH_PROD_TWILIO_PHONE_NUMBER

# Public URL for Twilio webhooks (your CapRover app URL)
PUBLIC_URL=https://acme-supervisor-backend.REPLACE_WITH_YOUR_DOMAIN

# OpenAI Configuration
OPENAI_API_KEY=REPLACE_WITH_PROD_OPENAI_API_KEY
OPENAI_REALTIME_MODEL=gpt-realtime-mini-2025-12-15
OPENAI_LLM_MODEL=gpt-5-mini-2025-08-07
TRANSLATION_MODEL=gpt-5-mini-2025-08-07

# JWT Security (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=REPLACE_WITH_PROD_JWT_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
CORS_ORIGINS=https://acme-supervisor-frontend.REPLACE_WITH_YOUR_DOMAIN
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600

# Bootstrap Admin (DISABLE after initial setup)
ENABLE_BOOTSTRAP_ADMIN=false
BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.com
BOOTSTRAP_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Hetzner Object Storage (PRODUCTION - shared bucket with uat/)
# Shared bucket with environment-specific folders
S3_ENDPOINT_URL=https://nbg1.your-objectstorage.com
S3_BUCKET_NAME=acme-supervisor
S3_ACCESS_KEY_ID=M0PAHM5K6P922M3OMJUG
S3_SECRET_ACCESS_KEY=Ebctiv9HlAyPI8elYi0OS0p761ctktg4mjUdYrkJ
S3_REGION=us-east-1
S3_PATH_PREFIX=prod/

# Recording Settings
RECORDING_ENABLED=true
RECORDING_FORMAT=mp3
RECORDING_SAMPLE_RATE=8000

# Health & Monitoring
HEALTH_CHECK_DEPENDENCIES=true
HEALTH_CHECK_CACHE_TTL=5
ENABLE_PROMETHEUS_METRICS=true

# Campaign & Call Settings
QUEUE_PROCESSOR_INTERVAL=30
MAX_CONCURRENT_CALLS=20
MAX_RETRY_ATTEMPTS=3
MAX_CALL_DURATION_SECONDS=600
CARRIER_RATE_LIMIT_SECONDS=2

# Language Configuration
SUPPORTED_LANGUAGES=en,es,fr,ht
DEFAULT_LANGUAGE=en
VOICE_EN=alloy
VOICE_ES=shimmer
VOICE_FR=coral
VOICE_HT=alloy
