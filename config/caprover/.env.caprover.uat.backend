# ============================================================================
# CAPROVER ENVIRONMENT VARIABLES - UAT BACKEND
# App: shifo-supervisor-uat-backend
# Project: shifo-supervisor-uat
# ============================================================================
# Copy-paste these into CapRover UI → App Configs → Environment Variables
# Replace all REPLACE_WITH_* placeholders with actual values
# ============================================================================

# Core Configuration
ENVIRONMENT=uat
LOG_LEVEL=info
LOG_FORMAT=json

# Database Configuration (CapRover internal services - UAT project)
MONGODB_URI=mongodb://srv-captain--shifo-supervisor-uat-mongodb:27017/shifo
MONGODB_DATABASE=shifo

# Redis Configuration (CapRover internal services - UAT project)
REDIS_URL=redis://srv-captain--shifo-supervisor-uat-redis:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://srv-captain--shifo-supervisor-uat-redis:6379/0
CELERY_RESULT_BACKEND=redis://srv-captain--shifo-supervisor-uat-redis:6379/0

# Twilio Credentials (UAT - can use same or test credentials)
TWILIO_ACCOUNT_SID=REPLACE_WITH_UAT_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_UAT_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=REPLACE_WITH_UAT_TWILIO_PHONE_NUMBER

# Public URL for Twilio webhooks (your CapRover app URL)
PUBLIC_URL=https://shifo-supervisor-uat-backend.REPLACE_WITH_YOUR_DOMAIN

# OpenAI Configuration
OPENAI_API_KEY=REPLACE_WITH_UAT_OPENAI_API_KEY
OPENAI_REALTIME_MODEL=gpt-realtime-mini-2025-12-15
OPENAI_LLM_MODEL=gpt-5-mini-2025-08-07
TRANSLATION_MODEL=gpt-5-mini-2025-08-07

# JWT Security (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=REPLACE_WITH_UAT_JWT_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration (staging allows all origins by default)
# CORS_ORIGINS is only strictly enforced in production
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600

# Bootstrap Admin (enable for initial setup, disable after)
ENABLE_BOOTSTRAP_ADMIN=true
BOOTSTRAP_ADMIN_EMAIL=admin@uat.example.com
BOOTSTRAP_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Hetzner Object Storage (UAT - shared bucket with prod/)
# Shared bucket with environment-specific folders
S3_ENDPOINT_URL=https://nbg1.your-objectstorage.com
S3_BUCKET_NAME=shifo-supervisor
S3_ACCESS_KEY_ID=M0PAHM5K6P922M3OMJUG
S3_SECRET_ACCESS_KEY=Ebctiv9HlAyPI8elYi0OS0p761ctktg4mjUdYrkJ
S3_REGION=us-east-1
S3_PATH_PREFIX=uat/

# Recording Settings
RECORDING_ENABLED=true
RECORDING_FORMAT=mp3
RECORDING_SAMPLE_RATE=8000

# Health & Monitoring
HEALTH_CHECK_DEPENDENCIES=true
HEALTH_CHECK_CACHE_TTL=5
ENABLE_PROMETHEUS_METRICS=true

# Campaign & Call Settings
QUEUE_PROCESSOR_INTERVAL=30
MAX_CONCURRENT_CALLS=5
MAX_RETRY_ATTEMPTS=3
MAX_CALL_DURATION_SECONDS=600
CARRIER_RATE_LIMIT_SECONDS=2

# Language Configuration
SUPPORTED_LANGUAGES=en,es,fr,ht
DEFAULT_LANGUAGE=en
VOICE_EN=alloy
VOICE_ES=shimmer
VOICE_FR=coral
VOICE_HT=alloy
