# ============================================================================
# CAPROVER ENVIRONMENT VARIABLES - UAT BEAT
# App: acme-supervisor-uat-beat
# Project: acme-supervisor-uat
# ============================================================================
# Copy-paste these into CapRover UI → App Configs → Environment Variables
# Replace all REPLACE_WITH_* placeholders with actual values
# ============================================================================

# Core Configuration
ENVIRONMENT=uat
LOG_LEVEL=info
LOG_FORMAT=json

# Database Configuration (CapRover internal services - UAT project)
MONGODB_URI=mongodb://srv-captain--acme-supervisor-uat-mongodb:27017/acme
MONGODB_DATABASE=acme

# Redis Configuration (CapRover internal services - UAT project)
REDIS_URL=redis://srv-captain--acme-supervisor-uat-redis:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://srv-captain--acme-supervisor-uat-redis:6379/0
CELERY_RESULT_BACKEND=redis://srv-captain--acme-supervisor-uat-redis:6379/0

# Campaign & Call Settings (for scheduled tasks)
QUEUE_PROCESSOR_INTERVAL=30
MAX_CONCURRENT_CALLS=5
MAX_RETRY_ATTEMPTS=3

# Graceful Shutdown
GRACEFUL_SHUTDOWN_TIMEOUT=30
